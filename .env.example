# Environment variables for pay-platform.
#
# Rule: this file (and the platform itself) only declares INFRASTRUCTURE
# and OPERATIONAL config — never application state. Account state lives
# in the database, not env vars.

# ENVIRONMENT
PORT=3030
MODE=development
LOG_LEVEL=TRACE

# DATABASE
DATABASE_URL=postgresql://admin:devpass@localhost:5434/pay_platform_db

# SERVICE
SERVICE_DOMAIN=localhost
SERVICE_AUTH_SECRET= # 32 random bytes, base64 encoded. Used for JWT signing.

# AUTH
CHALLENGE_TTL=900
SESSION_TTL=21600
